# Copy to `.env` and fill in. `.env` is gitignored.
#
# Hugging Face access token — required to run E2E tests against gated
# datasets (e.g. facebook/flores, laurievb/OpenLID). Get one at
# https://huggingface.co/settings/tokens (read-only is enough).
#
# Without this token the gated-dataset tests skip; WiLi-2018 and papluca
# still run because they are ungated.
HF_TOKEN=
